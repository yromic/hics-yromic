<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- TITLE -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="14dp"
        android:fontFamily="@font/poppinmedium"
        android:text="History Monitoring"
        android:textColor="@color/hijau_end"
        android:textSize="18sp" />

    <!-- SCROLL -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- FILTER CARD -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- FILTER HEADER -->

                    <LinearLayout
                        android:id="@+id/layoutFilterHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="12dp"
                        android:paddingTop="10dp"
                        android:paddingRight="12dp"
                        android:paddingBottom="10dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            app:tint="@color/hijau_end" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/poppinsbold"
                            android:text="Filter History"
                            android:textColor="@color/hijau_end"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/ivFilterArrow"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/hijau_end" />

                    </LinearLayout>

                    <!-- FILTER CONTENT -->

                    <LinearLayout
                        android:id="@+id/layoutFilterContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:paddingBottom="12dp"
                        android:visibility="gone">

                        <!-- CHIP FILTER -->

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <CheckBox
                                    android:id="@+id/cbAll"
                                    android:layout_width="wrap_content"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_chip"
                                    android:button="@null"
                                    android:checked="true"
                                    android:gravity="center"
                                    android:minWidth="0dp"
                                    android:paddingHorizontal="12dp"
                                    android:text="Semua"
                                    android:textColor="@drawable/chip_text_selector"
                                    android:textSize="12sp" />

                                <Space
                                    android:layout_width="6dp"
                                    android:layout_height="wrap_content" />

                                <CheckBox
                                    android:id="@+id/cbppm"
                                    android:layout_width="wrap_content"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_chip"
                                    android:button="@null"
                                    android:checked="true"
                                    android:gravity="center"
                                    android:minWidth="0dp"
                                    android:paddingHorizontal="12dp"
                                    android:text="PPM"
                                    android:textColor="@drawable/chip_text_selector"
                                    android:textSize="12sp" />

                                <Space
                                    android:layout_width="6dp"
                                    android:layout_height="wrap_content" />

                                <CheckBox
                                    android:id="@+id/cbPh"
                                    android:layout_width="wrap_content"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_chip"
                                    android:button="@null"
                                    android:checked="true"
                                    android:gravity="center"
                                    android:minWidth="0dp"
                                    android:paddingHorizontal="12dp"
                                    android:text="pH"
                                    android:textColor="@drawable/chip_text_selector"
                                    android:textSize="12sp" />

                                <Space
                                    android:layout_width="6dp"
                                    android:layout_height="wrap_content" />

                                <CheckBox
                                    android:id="@+id/cbWaterTemp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_chip"
                                    android:button="@null"
                                    android:checked="true"
                                    android:gravity="center"
                                    android:minWidth="0dp"
                                    android:paddingHorizontal="12dp"
                                    android:text="Water Temp"
                                    android:textColor="@drawable/chip_text_selector"
                                    android:textSize="12sp" />

                                <Space
                                    android:layout_width="6dp"
                                    android:layout_height="wrap_content" />

                                <CheckBox
                                    android:id="@+id/cbairTemp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_chip"
                                    android:button="@null"
                                    android:checked="true"
                                    android:gravity="center"
                                    android:minWidth="0dp"
                                    android:paddingHorizontal="12dp"
                                    android:text="Air Temp"
                                    android:textColor="@drawable/chip_text_selector"
                                    android:textSize="12sp" />

                                <Space
                                    android:layout_width="6dp"
                                    android:layout_height="wrap_content" />

                                <CheckBox
                                    android:id="@+id/cblight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_chip"
                                    android:button="@null"
                                    android:checked="true"
                                    android:gravity="center"
                                    android:minWidth="0dp"
                                    android:paddingHorizontal="12dp"
                                    android:text="Light"
                                    android:textColor="@drawable/chip_text_selector"
                                    android:textSize="12sp" />

                                <Space
                                    android:layout_width="6dp"
                                    android:layout_height="wrap_content" />

                                <CheckBox
                                    android:id="@+id/cbwaterLevel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_chip"
                                    android:button="@null"
                                    android:checked="true"
                                    android:gravity="center"
                                    android:minWidth="0dp"
                                    android:paddingHorizontal="12dp"
                                    android:text="Water Level"
                                    android:textColor="@drawable/chip_text_selector"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </HorizontalScrollView>

                        <!-- BUTTON FILTER -->

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnRangeDate"
                                android:layout_width="0dp"
                                android:layout_height="38dp"
                                android:layout_weight="2"
                                android:background="@drawable/bg_date"
                                android:backgroundTint="@null"
                                android:text="Rentang Waktu"
                                android:textAllCaps="false"
                                android:textColor="@color/hijau_end"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <Space
                                android:layout_width="8dp"
                                android:layout_height="wrap_content" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnClearFilter"
                                android:layout_width="0dp"
                                android:layout_height="38dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_reset"
                                android:backgroundTint="@null"
                                android:text="Reset"
                                android:textAllCaps="false"
                                android:textColor="@color/hijau_end"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- EXPORT -->

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnExport"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/hijau_end"
                            android:text="Export"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- TOTAL -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppinsbold"
                        android:text="Total Data : "
                        android:textColor="@color/hijau_end"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvTotalData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppinsbold"
                        android:text="0"
                        android:textColor="@color/hijau_end"
                        android:textSize="14sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- LOADING -->

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:visibility="gone" />

            <!-- TABLE -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <HorizontalScrollView
                    android:id="@+id/horizontalScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true"
                    android:scrollbars="horizontal">

                    <LinearLayout
                        android:id="@+id/tableContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- HEADER -->


                        <LinearLayout
                            android:id="@+id/headerLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/hijau_end"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="12dp">

                            <!-- TIMESTAMP -->

                            <TextView
                                android:id="@+id/headerTimestamp"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:minWidth="170dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="10dp"
                                android:text="Timestamp"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <!-- PH -->

                            <TextView
                                android:id="@+id/headerPh"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:minWidth="100dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="pH"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <!-- PPM -->

                            <TextView
                                android:id="@+id/headerPpm"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:minWidth="100dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="PPM"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <!-- WATER TEMP -->

                            <TextView
                                android:id="@+id/headerWaterTemp"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:minWidth="130dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Water Temp"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <!-- AIR TEMP -->

                            <TextView
                                android:id="@+id/headerAirTemp"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:minWidth="130dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Air Temp"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <!-- LIGHT -->

                            <TextView
                                android:id="@+id/headerLight"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:minWidth="100dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Light"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <!-- WATER LEVEL -->

                            <TextView
                                android:id="@+id/headerWaterLevel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:minWidth="140dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Water Level"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- RECYCLER -->

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvHistory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:focusable="false"
                            android:overScrollMode="never"
                            android:scrollbars="none" />

                    </LinearLayout>

                </HorizontalScrollView>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>